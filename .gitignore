.DS_Store

# Local secrets / env
backend/.env
.env
.env.*

# Local backend state (never commit runtime DB or CI temp files)
backend/data/state.json
backend/data/*.tmp
backend/data/.ci-state-*.json

# Accidental nested backend cwd (e.g. `npm start` from wrong folder)
backend/backend/

# Coverage (vitest --coverage)
coverage/

# Eval / matrix outputs (regenerate with `node scripts/eval/run-matrix.mjs`)
scripts/eval/*.smoke.out.csv
scripts/eval/*.out.csv
scripts/eval/*.ci.out.csv


# Node
**/node_modules/
node_modules/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

