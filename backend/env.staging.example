# Copy to backend/.env.staging (gitignored) for distill-api-staging secrets.
# Sourced after backend/.env by scripts/bootstrap-staging-secrets.sh

# Strongly recommended: different signing secret than production
# STAGING_BACKEND_SECRET=generate-with-openssl-rand-hex-32

# Same extension id(s) as production Fly app
# EXTENSION_CORS_ORIGINS=chrome-extension://YOUR_EXTENSION_ID

# Staging Postgres (separate Supabase project recommended)
# DATABASE_URL=postgresql://...

# DAILY_CREDITS=5000
